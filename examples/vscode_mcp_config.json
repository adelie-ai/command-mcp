{
  "mcpServers": {
    "gen-mcp-file-operations": {
      "command": "gen-mcp",
      "args": [
        "serve",
        "--config",
        "/path/to/config.toml",
        "--mode",
        "stdio"
      ],
      "env": {}
    },
    "gen-mcp-docker": {
      "command": "gen-mcp",
      "args": [
        "serve",
        "--config",
        "/path/to/docker_config.toml",
        "--mode",
        "stdio"
      ],
      "env": {}
    },
    "gen-mcp-custom": {
      "command": "gen-mcp",
      "args": [
        "serve",
        "--config",
        "/home/user/my-tools.toml",
        "--mode",
        "stdio"
      ],
      "env": {
        "PATH": "/usr/local/bin:/usr/bin:/bin"
      }
    },
    "gen-mcp-websocket": {
      "command": "gen-mcp",
      "args": [
        "serve",
        "--config",
        "/path/to/config.toml",
        "--mode",
        "websocket",
        "--host",
        "localhost",
        "--port",
        "8080"
      ],
      "env": {}
    }
  }
}

